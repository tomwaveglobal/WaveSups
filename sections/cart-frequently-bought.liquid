<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
</style>

{%- liquid
  assign upgrade_products = ''
  assign collected_products = ''
  
  # Collect all unique products from cart items' metafields
  for item in cart.items
    assign metafield_value = item.product.metafields.custom.popular_upgrades
    
    # Handle product_list type metafield
    if metafield_value.type == 'list.product_reference'
      for upgrade_product in metafield_value.value
        assign product_id = upgrade_product.id | append: ''
        unless collected_products contains product_id
          if upgrade_products == blank
            assign upgrade_products = upgrade_product.handle
          else
            assign upgrade_products = upgrade_products | append: ',' | append: upgrade_product.handle
          endif
          assign collected_products = collected_products | append: ',' | append: product_id
        endunless
      endfor
    # Handle text/string type metafield with comma-separated handles
    elsif metafield_value != blank
      assign handles = metafield_value | split: ','
      for handle in handles
        assign clean_handle = handle | strip
        unless upgrade_products contains clean_handle
          if upgrade_products == blank
            assign upgrade_products = clean_handle
          else
            assign upgrade_products = upgrade_products | append: ',' | append: clean_handle
          endif
        endunless
      endfor
    endif
  endfor
  
  # Convert to array
  if upgrade_products != blank
    assign upgrade_handles = upgrade_products | split: ','
  endif
-%}

{%- if upgrade_products != blank -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %}">
    
    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank -%}
      <div class="title-wrapper leading-none grid gap-2 {{ section.settings.heading_alignment }} mb-8">
        {%- if section.settings.subheading != blank -%}
          <p class="heading normal-case subtitle-sm leading-none tracking-none">
            {{- section.settings.subheading | escape -}}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }} leading-none tracking-tight">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="rte leading-normal">
            {{- section.settings.description -}}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="cart-fbt-wrapper grid gap-8">
      <!-- Products Grid -->
      <motion-list class="product-grid card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid">
        {%- for handle in upgrade_handles limit: section.settings.product_limit -%}
          {%- assign upgrade_product = all_products[handle] -%}
          {%- if upgrade_product != blank -%}
            <div class="cart-fbt-product-card relative">
              <label for="fbt-{{ upgrade_product.id }}" class="absolute top-3 left-3 z-10 cursor-pointer">
                <input type="checkbox" 
                  class="cart-fbt-checkbox w-5 h-5 cursor-pointer"
                  data-product-id="{{ upgrade_product.selected_or_first_available_variant.id }}"
                  data-product-price="{{ upgrade_product.selected_or_first_available_variant.price }}"
                  data-product-title="{{ upgrade_product.title | escape }}"
                  id="fbt-{{ upgrade_product.id }}">
              </label>
              {%- render 'product-card',
                product: upgrade_product,
                lazy_load: false,
                image_ratio: settings.product_image_ratio,
                image_fill: settings.product_image_fill,
                show_secondary_image: settings.product_secondary_image,
                show_vendor: settings.product_vendor,
                show_rating: settings.product_rating,
                show_quick_add: false,
                show_quick_view: settings.product_quick_view
              -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </motion-list>
      
      <!-- Summary Below Products -->
      <div class="cart-fbt-summary-wrapper max-w-2xl mx-auto w-full">
        <div class="cart-fbt-summary flex flex-col gap-5 p-6 border rounded-lg">
          <button type="button" class="button button--secondary w-full" id="select-all-fbt">
            <span>{{ section.settings.select_all_text | default: 'Select All' }}</span>
          </button>
          
          <div class="cart-fbt-selected-items grid gap-2" id="fbt-selected-items">
            <p class="text-sm text-opacity">{{ section.settings.no_items_text | default: 'Select items to add to cart' }}</p>
          </div>
          
          <div class="flex gap-4 items-center justify-between pt-4 border-t">
            <div class="heading text-xl">{{ section.settings.total_text | default: 'Total' }}</div>
            <div class="heading text-xl font-bold" id="fbt-total">{{ 0 | money }}</div>
          </div>
          
          <button type="button" class="button button--primary w-full" id="add-selected-fbt" disabled>
            <span>{{ section.settings.add_button_text | default: 'Add Selected to Cart' }}</span>
          </button>
          
          {%- if section.settings.footer_text != blank -%}
            <p class="text-xs text-opacity text-center">{{ section.settings.footer_text }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const checkboxes = document.querySelectorAll('.cart-fbt-checkbox');
    const selectAllBtn = document.getElementById('select-all-fbt');
    const addSelectedBtn = document.getElementById('add-selected-fbt');
    const totalDisplay = document.getElementById('fbt-total');
    const selectedItemsContainer = document.getElementById('fbt-selected-items');
    
    let allSelected = false;

    function updateSummary() {
      const checkedBoxes = Array.from(checkboxes).filter(cb => cb.checked);
      let total = 0;
      
      selectedItemsContainer.innerHTML = '';
      
      if (checkedBoxes.length === 0) {
        selectedItemsContainer.innerHTML = '<p class="text-sm text-opacity">{{ section.settings.no_items_text | default: "Select items to add to cart" }}</p>';
        addSelectedBtn.disabled = true;
      } else {
        checkedBoxes.forEach(cb => {
          total += parseFloat(cb.dataset.productPrice);
          const itemEl = document.createElement('div');
          itemEl.className = 'text-sm flex justify-between gap-4';
          itemEl.innerHTML = `
            <span class="flex-1">${cb.dataset.productTitle}</span>
            <span class="font-medium">${Shopify.formatMoney(cb.dataset.productPrice, {{ shop.money_format | json }})}</span>
          `;
          selectedItemsContainer.appendChild(itemEl);
        });
        addSelectedBtn.disabled = false;
      }
      
      totalDisplay.textContent = Shopify.formatMoney(total, {{ shop.money_format | json }});
      
      // Update select all button text
      allSelected = checkedBoxes.length === checkboxes.length;
      selectAllBtn.querySelector('span').textContent = allSelected ? '{{ section.settings.deselect_all_text | default: "Deselect All" }}' : '{{ section.settings.select_all_text | default: "Select All" }}';
    }

    selectAllBtn.addEventListener('click', function() {
      allSelected = !allSelected;
      checkboxes.forEach(cb => cb.checked = allSelected);
      updateSummary();
    });

    checkboxes.forEach(cb => {
      cb.addEventListener('change', updateSummary);
    });

    addSelectedBtn.addEventListener('click', function() {
      const checkedBoxes = Array.from(checkboxes).filter(cb => cb.checked);
      const items = checkedBoxes.map(cb => ({
        id: cb.dataset.productId,
        quantity: 1
      }));

      this.disabled = true;
      this.querySelector('span').textContent = 'Adding...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ items: items })
      })
      .then(response => response.json())
      .then(data => {
        window.location.reload();
      })
      .catch((error) => {
        console.error('Error:', error);
        this.disabled = false;
        this.querySelector('span').textContent = '{{ section.settings.add_button_text | default: "Add Selected to Cart" }}';
        alert('Error adding items to cart. Please try again.');
      });
    });
  });
</script>
{%- else -%}
  <!-- Debug: No upgrade products found -->
  {%- comment -%}
  Cart items: {{ cart.items | size }}
  {%- for item in cart.items -%}
    Product: {{ item.product.title }}
    Metafield: {{ item.product.metafields.custom.popular_upgrades }}
  {%- endfor -%}
  {%- endcomment -%}
{%- endif -%}

{% schema %}
{
  "name": "Bought Together",
  "settings": [
    {
      "type": "paragraph",
      "content": "Products are automatically pulled from the 'custom.popular_upgrades' metafield. Use either a Product List metafield or comma-separated product handles (e.g., 'handle-1,handle-2')."
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Maximum products to show",
      "default": 6,
      "min": 2,
      "max": 12,
      "step": 1
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "2",
      "label": "Mobile columns"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Bought Together"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "lg:text-2xl text-2xl",
          "label": "Small"
        },
        {
          "value": "lg:text-3xl text-2xl",
          "label": "Medium"
        },
        {
          "value": "lg:text-4xl text-2xl",
          "label": "Large"
        },
        {
          "value": "lg:text-5xl text-2xl",
          "label": "Extra Large"
        }
      ],
      "default": "lg:text-4xl text-2xl",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "text-left",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-right",
          "label": "Right"
        }
      ],
      "default": "text-left"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Button & Text Labels"
    },
    {
      "type": "text",
      "id": "select_all_text",
      "label": "Select all button text",
      "default": "Select All"
    },
    {
      "type": "text",
      "id": "deselect_all_text",
      "label": "Deselect all button text",
      "default": "Deselect All"
    },
    {
      "type": "text",
      "id": "add_button_text",
      "label": "Add to cart button text",
      "default": "Add Selected to Cart"
    },
    {
      "type": "text",
      "id": "total_text",
      "label": "Total label",
      "default": "Total"
    },
    {
      "type": "text",
      "id": "no_items_text",
      "label": "No items selected text",
      "default": "Select items to add to cart"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text",
      "default": "Discounts applied at checkout"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show divider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "Rounded corners"
    }
  ],
  "presets": [
    {
      "name": "Bought Together"
    }
  ],
  "templates": [
    "cart"
  ]
}
{% endschema %}