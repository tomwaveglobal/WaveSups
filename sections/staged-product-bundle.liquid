<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
</style>

{{ 'product-bundle.css' | asset_url | stylesheet_tag }}
{{ 'staged-product-bundle.css' | asset_url | stylesheet_tag }}
<script src="{{ 'staged-product-bundle.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign controls = 'StagedBundle-' | append: section.id
  assign stage_blocks = section.blocks | where: 'type', 'stage'
  assign stage_count = stage_blocks.size
-%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank -%}
      <div class="staged-bundle__intro title-wrapper leading-none grid gap-2 {{ section.settings.heading_alignment }} mb-8 lg:mb-10">
        {%- if section.settings.subheading != blank -%}
          <p class="heading normal-case subtitle-sm leading-none tracking-none">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }} leading-none tracking-tight">
            {{- section.settings.heading -}}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="rte leading-normal">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <staged-product-bundle
      class="staged-bundle block"
      id="{{ controls }}"
      data-current="0"
      data-stage-count="{{ stage_count }}"
      data-remove-label="{{ 'sections.product_bundle.remove' | t | escape }}"
    >
      {%- comment -%} Stepper {%- endcomment -%}
      <ol class="staged-bundle__steps flex items-center gap-2 md:gap-3 mb-7 lg:mb-9" role="list" data-staged-bundle-steps>
        {%- for block in stage_blocks -%}
          <li class="staged-bundle__step flex items-center gap-2 md:gap-3 grow" data-step-item="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="staged-bundle__step-btn flex items-center gap-2 text-left{% if forloop.first %} is-current{% endif %}"
              data-staged-bundle-step="{{ forloop.index0 }}"
              {% unless forloop.first %}disabled{% endunless %}
            >
              <span class="staged-bundle__step-num flex items-center justify-center shrink-0 rounded-full font-medium">{{ forloop.index }}</span>
              <span class="staged-bundle__step-label flex flex-col leading-tight">
                <span class="text-sm font-medium">{{ block.settings.title | default: 'Step' | escape }}</span>
                <span class="staged-bundle__step-meta text-xs text-opacity">
                  {%- if block.settings.required -%}{{ 'Required' }}{%- else -%}{{ 'Optional' }}{%- endif -%}
                </span>
              </span>
            </button>
            {%- unless forloop.last -%}<span class="staged-bundle__step-line grow" aria-hidden="true"></span>{%- endunless -%}
          </li>
        {%- endfor -%}
      </ol>

      <div class="staged-bundle__layout block lg:flex lg:gap-10 lg:items-start">
        <div class="staged-bundle__stages lg:grow">
          {%- for block in stage_blocks -%}
            {%- liquid
              assign block_collection = block.settings.collection
              assign block_products = block.settings.products | default: block_collection.products
              assign max_picks = block.settings.max_picks | default: 1
            -%}
            <div
              class="staged-bundle__stage{% unless forloop.first %} is-hidden{% endunless %}"
              data-stage="{{ forloop.index0 }}"
              data-max-picks="{{ max_picks }}"
              {% if block.settings.required %}data-required{% endif %}
              {% unless forloop.first %}hidden{% endunless %}
              {{ block.shopify_attributes }}
            >
              <div class="staged-bundle__stage-head flex items-baseline justify-between gap-4 mb-5">
                <div class="grid gap-1">
                  {%- if block.settings.title != blank -%}
                    <h3 class="heading text-xl lg:text-2xl leading-tight tracking-tight">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="text-sm text-opacity leading-normal">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                </div>
                <p class="staged-bundle__stage-hint text-xs text-opacity shrink-0 whitespace-nowrap" data-stage-hint>
                  {%- if max_picks > 1 -%}Choose up to {{ max_picks }}{%- else -%}Choose 1{%- endif -%}
                </p>
              </div>

              <motion-list class="product-grid card-grid card-grid--{{ block.settings.columns | default: 3 }} mobile:card-grid--{{ section.settings.columns_mobile }} grid">
                {%- for product in block_products limit: block.settings.product_limit -%}
                  {%- render 'product-card-bundle',
                    product: product,
                    product_id: product.id,
                    section_id: section.id,
                    lazy_load: false,
                    image_ratio: settings.product_image_ratio,
                    image_fill: settings.product_image_fill,
                    show_secondary_image: settings.product_secondary_image,
                    show_multiple_images: settings.product_multiple_images,
                    show_vendor: settings.product_vendor,
                    show_rating: settings.product_rating,
                    show_sold_out: settings.product_sold_out,
                    show_save_amount: settings.product_save_amount,
                    save_type: settings.product_save_type,
                    show_variant_labels: section.settings.show_variant_labels,
                    picker_type: section.settings.picker_type,
                    enable_color_swatches: section.settings.enable_color_swatches,
                    color_swatch_type: section.settings.color_swatch_type,
                    controls: controls
                  -%}
                {%- else -%}
                  {%- for i in (1..3) -%}
                    {%- capture placeholder -%}product-{% cycle '1', '2', '3', '4', '5', '6' %}{%- endcapture -%}
                    {%- render 'product-card-placeholder', placeholder: placeholder, image_ratio: settings.product_image_ratio, show_vendor: settings.product_vendor -%}
                  {%- endfor -%}
                {%- endfor -%}
              </motion-list>
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Summary sidebar {%- endcomment -%}
        <div class="staged-bundle__summary lg:grow-0 lg:shrink-0">
          <sticky-element class="staged-bundle__summary-inner flex flex-col gap-5 lg:sticky top-0">
            <div class="staged-bundle__summary-head flex items-center justify-between gap-3">
              <p class="heading text-lg lg:text-xl leading-none tracking-tight">{{ section.settings.summary_title | default: 'Your bundle' | escape }}</p>
              <span class="staged-bundle__count text-sm text-opacity" data-staged-bundle-count>0</span>
            </div>

            <ul class="staged-bundle__selections grid gap-4 m-0 p-0" data-staged-bundle-selections role="list"></ul>
            <p class="staged-bundle__empty text-sm text-opacity" data-staged-bundle-empty>{{ 'Your selections will appear here as you build your bundle.' }}</p>

            <div class="staged-bundle__footer grid gap-3 pt-1">
              <div class="flex items-center justify-between gap-4">
                <span class="heading text-lg shrink-0">{{ 'sections.product_bundle.total' | t }}</span>
                <span class="heading text-lg grow font-bold text-right" data-staged-bundle-total>{{ 0 | money_with_currency }}</span>
              </div>

              <div class="staged-bundle__nav flex items-center gap-3">
                <button type="button" class="staged-bundle__back link cursor-pointer shrink-0" data-staged-bundle-prev hidden>{{ 'Back' }}</button>
                <button type="button" class="button button--primary grow" is="hover-button" data-staged-bundle-next>
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">{{ 'Next' }}</span>
                </button>
                <button type="button" class="button button--primary grow" is="hover-button" data-staged-bundle-submit hidden disabled>
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">{{ 'sections.product_bundle.add_to_cart' | t }}</span>
                </button>
              </div>

              <p class="text-xs text-opacity text-center">{{ 'sections.product_bundle.discounts_at_checkout' | t }}</p>
              <div class="product-form__error-message alert alert--error text-sm font-medium leading-tight text-center" role="alert" data-staged-bundle-error hidden></div>
            </div>
          </sticky-element>
        </div>
      </div>
    </staged-product-bundle>
  </div>
</div>

{% schema %}
{
  "name": "Staged bundle",
  "tag": "section",
  "class": "section-staged-bundle",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Build your bundle"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "lg:text-2xl text-2xl", "label": "Small" },
        { "value": "lg:text-3xl text-2xl", "label": "Medium" },
        { "value": "lg:text-4xl text-2xl", "label": "Large" },
        { "value": "lg:text-5xl text-2xl", "label": "Extra large" }
      ],
      "default": "lg:text-4xl text-2xl",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "div", "label": "Div" }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-left"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "summary_title",
      "label": "Bundle summary title",
      "default": "Your bundle"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2",
      "label": "Columns on mobile"
    },
    {
      "type": "checkbox",
      "id": "show_variant_labels",
      "default": true,
      "label": "Show variant labels"
    },
    {
      "type": "select",
      "id": "picker_type",
      "options": [
        { "value": "dropdown", "label": "Dropdown" },
        { "value": "button", "label": "Button" }
      ],
      "default": "button",
      "label": "Variant picker type"
    },
    {
      "visible_if": "{{ section.settings.picker_type == 'button' }}",
      "type": "checkbox",
      "id": "enable_color_swatches",
      "default": true,
      "label": "Enable color swatches"
    },
    {
      "visible_if": "{{ section.settings.picker_type == 'button' and section.settings.enable_color_swatches == true }}",
      "type": "select",
      "id": "color_swatch_type",
      "options": [
        { "value": "color", "label": "Color" },
        { "value": "variant", "label": "Variant image" }
      ],
      "default": "color",
      "label": "Color swatch type"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show divider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "Rounded"
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Stage title",
          "default": "Choose a product"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Stage description"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "info": "If on, the customer must pick at least one product in this stage before continuing.",
          "default": true
        },
        {
          "type": "range",
          "id": "max_picks",
          "label": "Products to choose",
          "info": "How many products the customer can pick in this stage.",
          "min": 1,
          "max": 6,
          "step": 1,
          "default": 1
        },
        {
          "type": "header",
          "content": "Product source"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Products",
          "info": "Overrides the collection if set."
        },
        {
          "type": "range",
          "id": "product_limit",
          "label": "Products to show",
          "min": 2,
          "max": 24,
          "step": 1,
          "default": 8
        },
        {
          "type": "range",
          "id": "columns",
          "min": 1,
          "max": 4,
          "step": 1,
          "default": 3,
          "label": "Columns"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Staged bundle",
      "category": "Products",
      "blocks": [
        { "type": "stage" },
        { "type": "stage" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"],
    "templates": ["password"]
  }
}
{% endschema %}
