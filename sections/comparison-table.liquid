<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
    --values-columns-count: {{ section.blocks | where: 'type', 'values' | size }};
    --comparison-column-min: 16rem;
  }

  {%- liquid
    assign comparison_values_count = section.blocks | where: 'type', 'values' | size
  -%}

  {%- if comparison_values_count > 4 -%}
    #shopify-section-{{ section.id }} {
      --comparison-column-min: 18rem;
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .comparison-table__row {
    grid-template-columns: repeat(var(--values-columns-count), minmax(var(--comparison-column-min), 1fr));
  }

  #shopify-section-{{ section.id }} .comparison-table .thead .horizontal-product {
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .comparison-table .thead .horizontal-product__media {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .comparison-table__sticky .horizontal-product {
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .comparison-table__sticky .horizontal-product__media {
    width: var(--cart-item-media-width);
    max-width: var(--cart-item-media-width);
  }

  #shopify-section-{{ section.id }} .comparison-table-wrapper {
    position: relative;
    overflow-x: hidden;
  }

  #shopify-section-{{ section.id }} .comparison-table__heading-controls .button[disabled] {
    opacity: 0.45;
    pointer-events: none;
  }

  {%- unless section.settings.full_width -%}
    /* Same inset as product-details / specifications at xl */
    @media screen and (min-width: 1536px) {
      #shopify-section-{{ section.id }} :is(.title-wrapper, .comparison-table) {
        padding-inline: calc(var(--grid-gap) * 2);
      }
    }
  {%- endunless -%}

  /* Narrower min column width on small screens so horizontal scroll scales better */
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --comparison-column-min: min(200px, 42vw);
    }

    #shopify-section-{{ section.id }} .comparison-table__row {
      grid-template-columns: repeat(var(--values-columns-count), minmax(var(--comparison-column-min), 1fr));
    }
  }

</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}"{% if section.settings.transparent_header %} allow-transparent-header{% endif %}>
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- assign values_blocks = section.blocks | where: 'type', 'values' -%}
    {%- assign headings_block = section.blocks | where: 'type', 'headings' | first -%}

    {%- capture comparison_controls -%}
      <div class="comparison-table__heading-controls indicators hidden lg:flex gap-2d5" role="group" aria-label="Comparison table navigation">
        <button type="button" class="comparison-table__scroll-button comparison-table__scroll-button--prev button button--secondary" data-comparison-scroll-prev aria-label="Previous comparison items">
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            <svg class="icon icon-chevron-left icon-md transform" viewBox="0 0 24 24" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 6L8 12L14 18"></path>
            </svg>
          </span>
          <span class="btn-loader">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
        <button type="button" class="comparison-table__scroll-button comparison-table__scroll-button--next button button--secondary" data-comparison-scroll-next aria-label="Next comparison items">
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            <svg class="icon icon-chevron-right icon-md transform" viewBox="0 0 24 24" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6L16 12L10 18"></path>
            </svg>
          </span>
          <span class="btn-loader">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    {%- endcapture -%}

    {%- render 'section-heading', section: section, section_button: comparison_controls -%}

    {%- if values_blocks.size > 0 -%}
      <div class="comparison-table-wrapper">
      <comparison-table class="comparison-table grid gap-4 md:gap-10 scroll-area">
        {%- assign tfoot_content = blank -%}
        {%- capture thead_content -%}
          {%- for block in values_blocks -%}
            <div class="comparison-table__column">
              {%- if block.settings.product != blank -%}
                {%- liquid
                  assign card_product = block.settings.product
                  assign first_available_variant = blank
                  if card_product.has_only_default_variant == false and section.settings.first_available_variant
                    assign first_available_variant = card_product.first_available_variant
                  endif
                  assign featured_media = first_available_variant.featured_media | default: card_product.featured_media
                -%}
                <div class="horizontal-product flex items-start flex-col gap-4">
                  <a class="horizontal-product__media media media--{{ settings.product_image_ratio }}{% unless settings.product_image_fill %} media--contain{% endunless %} relative overflow-hidden shrink-0" href="{{ card_product.url }}">
                    {%- if featured_media -%}
                      {%- assign max_width = featured_media.width -%}
                      {%- assign base_media_width = 320 -%}
                      {%- capture sizes -%}(max-width: 767px) min(200px, 42vw), {{ base_media_width }}px{%- endcapture -%}
                      {%- capture widths -%}{{ base_media_width | at_most: max_width }}, {{ base_media_width | times: 1.5 | at_most: max_width | round }}, {{ base_media_width | times: 2 | at_most: max_width | round }}{%- endcapture -%}
                      {{- featured_media | image_url: width: max_width | image_tag: loading: 'lazy', widths: widths, sizes: sizes, is: 'lazy-image' -}}
                    {%- else -%}
                      {{- 'product-1' | placeholder_svg_tag -}}
                    {%- endif -%}
                  </a>
                  <div class="horizontal-product__details grow flex flex-col justify-start align-self-center gap-1d5 w-full">
                    <div class="flex flex-col gap-1">
                      <div class="block">
                        {%- if section.settings.show_vendor -%}
                          <p class="horizontal-product__vendor text-xs text-opacity">{{ card_product.vendor }}</p>
                        {%- endif -%}
                        <a href="{{ card_product.url }}" class="horizontal-product__title reversed-link font-medium text-base leading-tight">
                          {% if card_product.metafields.product_card_overwrite.title != blank %}
                            {{ card_product.metafields.product_card_overwrite.title | escape }}
                          {% else %}
                            {{- card_product.title | escape -}}
                          {% endif %}
                        </a>
                      </div>
                      {%- if first_available_variant != blank -%}
                        <p class="text-xs text-opacity leading-tight">{{ first_available_variant.title }}</p>
                      {%- endif -%}
                    </div>
                    {%- if section.settings.show_rating -%}
                      <div class="horizontal-product__reviews flex flex-col gap-1" {{ block.shopify_attributes }}>
                        {% comment %} {%- liquid
                          assign hide_rating = true
                          assign rating_max = 5
                          if card_product.metafields.reviewscouk.rating.value != blank
                            assign rating_value = card_product.metafields.reviewscouk.rating.value
                            assign rating_count = card_product.metafields.reviewscouk.rating.value
                            assign hide_rating = false
                          elsif card_product.metafields.reviews.rating.value != blank and card_product.metafields.reviews.rating_count.value > 0
                            assign rating_value = card_product.metafields.reviews.rating.value.rating | round: 1
                            assign rating_count = card_product.metafields.reviews.rating_count.value
                            assign rating_max = card_product.metafields.reviews.rating.value.scale_max
                            assign hide_rating = false
                          endif
                        -%}
                        {%- unless hide_rating -%}
                          <div class="rating flex items-center gap-2 text-sm leading-tight" title="{{ 'general.accessibility.star_reviews_count' | t: count: rating_count | escape }}">
                            <span role="img" aria-label="{{ 'general.accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}">
                              {%- render 'icon', icon: 'star', size: 'xs' -%}
                            </span>
                            <span aria-hidden="true">{{ rating_value }}</span>
                          </div>
                        {%- endunless -%} {% endcomment %}
                        <div
                          class="ruk_rating_snippet text-sm leading-tight"
                          data-sku="{{ card_product.handle }};{{ card_product.variants | map: 'sku' | join: ';' }};{{ card_product.variants | map: 'id' | join: ';' }}"
                        ></div>
                      </div>
                    {%- endif -%}
                    <div class="flex flex-col gap-1">
                      {%- liquid
                        if section.settings.show_price
                          if first_available_variant != blank
                            render 'product-price', product: card_product, variant: first_available_variant, use_variant: true, class: 'flex flex-wrap items-end gap-2 text-sm'
                          else
                            render 'product-price', product: card_product, class: 'flex flex-wrap items-end gap-2 text-sm'
                          endif
                        endif
                      -%}
                    </div>
                  </div>
                </div>
                {%- capture tfoot_content -%}
                  {{- tfoot_content -}}
                  <div class="comparison-table__column">
                    {%- if first_available_variant != blank -%}
                      {%- capture product_form_id -%}QuickAddProductForm-{{ section.id }}-{{ card_product.id }}{%- endcapture -%}
                      {%- form 'product', card_product, is: 'product-form', id: product_form_id, class: 'grid gap-5' -%}
                        <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}" />
                        {%- liquid
                          if product.template_suffix != 'pre-order'
                            assign add_to_cart_label = 'products.product.add_to_cart' | t
                            assign add_to_cart_aria = 'products.product.add_to_cart_label' | t: title: card_product.title
                          else
                            assign add_to_cart_label = 'products.product.pre_order' | t
                            assign add_to_cart_aria = 'products.product.pre_order_label' | t: title: card_product.title
                          endif
                        -%}
                        <button type="submit" class="button button--primary w-full" is="hover-button" data-variant-id="{{ card_product.selected_or_first_available_variant.id }}" aria-label="{{ add_to_cart_aria | escape }}">
                          <span class="btn-fill" data-fill></span>
                          <span class="btn-text">
                            <span data-sold-out="{{ 'products.product.sold_out' | t | escape }}">
                              {{- add_to_cart_label -}}
                            </span>
                          </span>
                        </button>
                        <p class="text-center">
                          <a href="{{ card_product.url }}" class="link text-sm" aria-label="{{ 'products.product.view_product_label' | t: title: card_product.title | escape }}">
                            {{- 'products.product.view_product' | t -}}
                          </a>
                        </p>
                      {%- endform -%}
                    {%- else -%}
                      <a href="{{ card_product.url }}" class="button button--primary w-full" is="hover-link" aria-label="{{ 'products.product.view_product_label' | t: title: card_product.title | escape }}">
                        <span class="btn-fill" data-fill></span>
                        <span class="btn-text">
                          {{- 'products.product.view_product' | t -}}
                        </span>
                      </a>
                    {%- endif -%}
                  </div>
                {%- endcapture -%}
              {%- else -%}
                <div class="horizontal-product flex items-start flex-col gap-4">
                  <div class="horizontal-product__media media media--{{ settings.product_image_ratio }}{% unless settings.product_image_fill %} media--contain{% endunless %} relative overflow-hidden shrink-0" href="{{ card_product.url }}">
                    {{- 'product-1' | placeholder_svg_tag -}}
                  </div>
                  <div class="horizontal-product__details grow flex flex-col justify-start align-self-center gap-1d5 w-full">
                    <div class="flex flex-col gap-1">
                      <div class="block">
                        {%- if section.settings.show_vendor -%}
                          <p class="horizontal-product__vendor text-xs text-opacity">{{ 'products.product.vendor' | t }}</p>
                        {%- endif -%}
                        <a href="#" class="horizontal-product__title reversed-link font-medium text-base leading-tight">{{ 'onboarding.product_title' | t }}</a>
                      </div>
                    </div>
                    <div class="flex flex-col gap-1">
                      {%- liquid
                        if section.settings.show_price
                          render 'product-price', product: blank, class: 'flex flex-wrap items-end gap-2 text-sm'
                        endif
                      -%}
                    </div>
                  </div>
                </div>
                {%- capture tfoot_content -%}
                  {{- tfoot_content -}}
                  <div class="comparison-table__column">
                    <p class="button button--primary w-full" disabled="disabled">{{ 'products.product.sold_out' | t }}</p>
                  </div>
                {%- endcapture -%}
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endcapture -%}

        <div class="comparison-table__row grid gap-6 thead">
          {{- thead_content -}}
        </div>

        {%- if section.settings.sticky_product_info -%}
          <div class="comparison-table__sticky page-width{% if section.settings.full_width %} page-width--full{% endif %} scroll-area fixed z-1 top-0 left-0 w-full opacity-0 invisible">
            <div class="comparison-table__row grid gap-6 sticky">
              {{- thead_content -}}
            </div>
          </div>
        {%- endif -%}

        {%- for i in (1..25) -%}
          {%- liquid
            assign heading_key = 'heading_' | append: i
            assign value_key = 'value_' | append: i
            assign heading_value = headings_block.settings[heading_key]
          -%}
          
          {%- capture row_content -%}
            {%- for block in values_blocks -%}
              {%- if block.settings[value_key] != blank -%}
                <div class="comparison-table__column {{ block.settings.text_size }} rte">
                  {%- liquid
                    assign metafield_content = block.settings[value_key]
                    assign stripped_value = block.settings[value_key] | strip_html | strip | upcase

                    if stripped_value == 'FALSE'
                      render 'icon', icon: 'close-circle-filled'
                    elsif stripped_value == 'TRUE'
                      render 'icon', icon: 'check-circle-filled'
                    else
                      if metafield_content contains '<h6>'
                        if metafield_content contains 'class="metafield-single_line_text_field-array'
                          assign metafield_content = metafield_content | replace: 'class="metafield-single_line_text_field-array', 'class="metafield-single_line_text_field-array col-span-full'
                        elsif metafield_content contains 'class="metafield-rich_text_field'
                          assign metafield_content = metafield_content | replace: 'class="metafield-rich_text_field', 'class="metafield-rich_text_field col-span-full'
                        elsif metafield_content contains 'class='
                          assign metafield_content = metafield_content | replace: 'class="', 'class="col-span-full '
                        else
                          assign metafield_content = '<div class="col-span-full">' | append: metafield_content | append: '</div>'
                        endif
                        
                        assign metafield_content = metafield_content | replace_first: '<h6>', '<div class="grid gap-6 md:gap-10"><h6>'
                        assign metafield_content = metafield_content | replace: '<h6>', '</div><div class="col-span-full"><h6 class="leading-tight tracking-none">'
                        assign metafield_content = metafield_content | remove_first: '</div>'
                        assign metafield_content = metafield_content | append: '</div></div>'
                      else
                        assign metafield_content = '<div class="col-span-full">' | append: metafield_content | append: '</div>'
                      endif

                      echo metafield_content | default: '-'
                    endif
                  -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}
          
          {%- if heading_value != blank and row_content != blank -%}
            <div class="comparison-table__head heading text-base lg:text-lg xl:text-xl font-medium leading-tight">
              <span class="comparison-table__column">{{ heading_value }}</span>
            </div>
            <div class="comparison-table__row grid gap-6">{{ row_content }}</div>
          {%- endif -%}
        {%- endfor -%}

        <div class="comparison-table__row grid gap-6">
          {{- tfoot_content -}}
        </div>
      </comparison-table>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.comparison-table.name",
  "class": "comparison-table-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "sticky_product_info",
      "label": "t:sections.comparison-table.settings.sticky_product_info.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "first_available_variant",
      "default": true,
      "label": "t:sections.comparison-table.settings.first_available_variant.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.global.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "default": true,
      "label": "t:sections.global.settings.show_price.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "t:settings_schema.products.settings.show_rating.label",
      "info": "t:settings_schema.products.settings.show_rating.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__heading.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.global.settings.heading.label",
      "default": "Comparison table"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "t:sections.global.settings.heading_size.options__1.label"
        },
        {
          "value": "title-md",
          "label": "t:sections.global.settings.heading_size.options__2.label"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__3.label"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__4.label"
        }
      ],
      "default": "title-md",
      "label": "t:sections.global.settings.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.global.settings.heading_alignment.label",
      "options": [
        {
          "value": "text-left md:items-end md:flex-row",
          "label": "t:sections.global.settings.heading_alignment.options__1.label"
        },
        {
          "value": "text-center md:items-center",
          "label": "t:sections.global.settings.heading_alignment.options__2.label"
        },
        {
          "value": "text-right md:items-end md:flex-row-reverse",
          "label": "t:sections.global.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "text-center md:items-center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.global.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.global.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.global.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.global.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.global.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.global.settings.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.global.settings.heading_tag.options__7.label"
        },
        {
          "value": "span",
          "label": "t:sections.global.settings.heading_tag.options__8.label"
        },
        {
          "value": "p",
          "label": "t:sections.global.settings.heading_tag.options__9.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.global.settings.heading_tag.label",
      "info": "t:sections.global.settings.heading_tag.info"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.global.settings.subheading.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.global.settings.description.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.global.settings.button_label.label",
      "info": "t:sections.global.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.global.settings.button_link.label"
    },
    {
      "visible_if": "{{ section.settings.button_label != blank }}",
      "type": "checkbox",
      "id": "button_external",
      "label": "t:sections.global.settings.button_external.label",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.button_label != blank }}",
      "type": "checkbox",
      "id": "button_icon",
      "label": "t:sections.global.settings.button_icon.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__highlight.content",
      "info": "t:sections.global.settings.header__highlight.info"
    },
    {
      "type": "select",
      "id": "highlighted_text",
      "options": [
        {
          "value": "none",
          "label": "t:sections.global.settings.highlighted_text.options__1.label"
        },
        {
          "value": "text",
          "label": "t:sections.global.settings.highlighted_text.options__2.label"
        },
        {
          "value": "full_text",
          "label": "t:sections.global.settings.highlighted_text.options__3.label"
        },
        {
          "value": "half_text",
          "label": "t:sections.global.settings.highlighted_text.options__4.label"
        },
        {
          "value": "underline",
          "label": "t:sections.global.settings.highlighted_text.options__5.label"
        },
        {
          "value": "marker",
          "label": "t:sections.global.settings.highlighted_text.options__6.label"
        },
        {
          "value": "stencil",
          "label": "t:sections.global.settings.highlighted_text.options__7.label"
        },
        {
          "value": "scribble",
          "label": "t:sections.global.settings.highlighted_text.options__8.label"
        }
      ],
      "default": "none",
      "label": "t:sections.global.settings.highlighted_text.label"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text == 'scribble' }}",
      "type": "select",
      "id": "highlighted_scribble",
      "options": [
        {
          "value": "circle",
          "label": "t:sections.global.settings.highlighted_scribble.options__1.label"
        },
        {
          "value": "basic-underline",
          "label": "t:sections.global.settings.highlighted_scribble.options__2.label"
        },
        {
          "value": "sketch-underline",
          "label": "t:sections.global.settings.highlighted_scribble.options__3.label"
        },
        {
          "value": "squiggle-underline",
          "label": "t:sections.global.settings.highlighted_scribble.options__4.label"
        },
        {
          "value": "squiggle-underline-2",
          "label": "t:sections.global.settings.highlighted_scribble.options__5.label"
        }
      ],
      "default": "circle",
      "label": "t:sections.global.settings.highlighted_scribble.label",
      "info": "t:sections.global.settings.highlighted_scribble.info"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text != 'none' }}",
      "type": "checkbox",
      "id": "highlighted_reveal",
      "label": "t:sections.global.settings.highlighted_reveal.label",
      "default": false
