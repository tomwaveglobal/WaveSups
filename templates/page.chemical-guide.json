        "text_pAbThL": {
          "type": "text",
          "settings": {
            "text": "<p>Wondering how to keep your inflatable hot tub clean? Having the right routine and using the best chemicals will help. What hot tub chemicals do I need? Follow these simple steps to ensure you’re always soaking in sparkling clean water! </p>",
            "text_font": "body",
