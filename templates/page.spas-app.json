          }
        },
        "question_UdApBf": {
          "type": "question",
          "settings": {
            "title": "My spa won't connect to wifi, what do I do?",
            "text": "<p>Ensure that the Wave Spa is powered on. Press and hold the Wi-Fi button on the controller until you hear a long beep to reset the connection. Make sure you are trying to connect to a 2.4ghz network – our app supports this band width only. Make sure your spa controller is placed in an area with strong, stable Wi-Fi coverage. You can check the signal strength by testing it with your phone near the spa controller.<br/><br/></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_yXzw7b": {
          "type": "question",
          "settings": {
            "title": "How far can my spa be from the router?",
            "text": "<p>Our app can work up to 15m away from the router. When connecting, please ensure that you wait 60 seconds to find the spa and enter the correct network name and password for your home Wi-Fi.<br/><br/></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_WxGbC6": {
          "type": "question",
          "settings": {
            "title": "I didn't receive the activation email",
            "text": "<p>It might be because the email lands in your Spam folder – look for a 4-digit number<br/><br/></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_FRjHAP": {
          "type": "question",
          "settings": {
            "title": "How do I enable anti-freeze?",
            "text": "<p>Set the spa to 20°C and press the down button: this will activate AF (anti-freeze)<br/><br/></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_BXQJYA": {
          "type": "question",
          "settings": {
            "title": "I can't connect to IOS/Android",
            "text": "<p>If you're having trouble connecting to the Wave Spa app on iOS or Android, make sure you're using the latest version of the app and try clearing the cache or reinstalling it. iOS users may experience connectivity issues due to a recent update, our team is working on a fix, and we recommend using an Android device as a temporary workaround. If you're on Android and still having issues, try connecting via an iOS device if available.<br/><br/></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
