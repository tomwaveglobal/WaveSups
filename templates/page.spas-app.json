        "question_RXPMMU": {
          "type": "question",
          "settings": {
            "title": "How do I pair the app to my hot tub?",
            "text": "<p>View our handy guide <a href=\"https://cdn.shopify.com/s/files/1/0058/2284/0889/files/APP_instruction.pdf?v=1731588911\">here</a></p>",
            "highlighted_text": "none",
