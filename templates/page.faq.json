        "question-6": {
          "type": "question",
          "settings": {
            "title": "What payment options do you offer?",
            "text": "<p>We provide a selection of payment options including: Card payment (including Apple Pay, Google Pay and Shop Pay), PayPal, Klarna, DivideBuy and Super.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-7": {
          "type": "question",
          "settings": {
            "title": "What does pre order mean?",
            "text": "<p>This item is currently out of stock, but it is still available to order. As soon as your spa is ready it will be shipped out to you. More information on when your chosen spa will arrive is provided in your basket before checkout.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-8": {
          "type": "question",
          "settings": {
            "title": "What are your shipping costs?",
            "text": "<p>We offer free shipping on orders over £100</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-9": {
          "type": "question",
          "settings": {
            "title": "How long will it take to get my order?",
            "text": "<p>It depends on where you are. Orders processed here will take 5-7 business days to arrive. Overseas deliveries can take anywhere from 7-16 days. Delivery details will be provided in your confirmation email.<br/><br/></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_c3x4na": {
          "type": "question",
          "settings": {
            "title": "Where are your products from?",
            "text": "<p>Wave products are designed in Newcastle in the North East of England and are shipped from our UK warehouse</p>",
            "highlighted_text": "none",
