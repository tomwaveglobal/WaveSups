        "text_HPz7xK": {
          "type": "text",
          "settings": {
            "text": "<ul><li><strong>Creative Content Creation</strong><br/>Eye-catching photos and videos showcasing your adventures with Wave SUPs. We love educational and vlog-style content that highlights the fun, versatility, and quality of our products.</li><li><strong>Social Media Presence</strong><br/>An engaged and adventurous audience who resonates with your love for exploration and the outdoors.</li><li><strong>Passion for Adventure</strong><br/>A genuine enthusiasm for watersports and outdoor activities, with the ability to inspire others to join the Wave SUPs journey.</li><li><strong>Seasonal content</strong> <br/>Show how paddleboarding and kayaking can be enjoyed year-round, from sunny summer days to crisp autumn mornings. </li></ul><p><br/><strong>Who We’re Looking For</strong></p><ul><li><strong>Outdoor Enthusiasts:</strong> Highlight how our products can enhance camping trips, hiking adventures, and coastal explorations.</li><li><strong>Free Spirits:</strong> Capture the joy of being on the water, whether it’s a serene lake or a challenging sea paddle.</li><li><strong>Young Adventurers:</strong> Share your energy and enthusiasm for paddleboarding and kayaking.</li><li><strong>Explorers:</strong> Demonstrate the portability and durability of our SUPs by taking them to unique and scenic locations.<br/></li></ul>",
            "text_size": "subtext-md",
