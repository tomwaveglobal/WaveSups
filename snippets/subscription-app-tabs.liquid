{%- doc -%}
  Tab UI (One-time | Subscribe & Save) + delivery dropdown for the Shopify Subscriptions app block.
  Syncs with the app’s radios inside .shopify_subscriptions_app_container. Expects section_id to match
  the app container’s data-section-id (same as section.id on the main product section).
{%- enddoc -%}
{%- liquid
  assign tabs_config_id = 'SubscriptionTabsConfig-' | append: section_id | replace: '--', '-' | replace: '__', '-'
-%}

<script type="application/json" id="{{ tabs_config_id }}">
  {
    "sectionId": {{ section_id | json }},
    "productId": {{ product_id | json }}
  }
</script>

<script>
  (function () {
    const configEl = document.getElementById({{ tabs_config_id | json }});
    if (!configEl) return;

    const config = JSON.parse(configEl.textContent);
    const sectionId = config.sectionId;
    const productId = config.productId;

    function containerSelector() {
      return (
        '.shopify_subscriptions_app_container[data-section-id="' +
        CSS.escape(String(sectionId)) +
        '"]'
      );
    }

    function getContainer() {
      return document.querySelector(containerSelector());
    }

    function getVisibleBlock() {
      const c = getContainer();
      if (!c) return null;
      return c.querySelector(
        'section.shopify_subscriptions_app_block:not(.shopify_subscriptions_app_block--hidden)'
      );
    }

    function getSellingPlanInputs(block) {
      if (!block) return [];
      return Array.from(block.querySelectorAll('input[type="radio"][data-radio-type="selling_plan"]'));
    }

    function getOneTimeInput(block) {
      return block?.querySelector('input[type="radio"][data-radio-type="one_time_purchase"]') || null;
    }

    function decodeBasicEntities(text) {
      if (!text) return '';
      return String(text)
        .replace(/&amp;/gi, '&')
        .replace(/&lt;/gi, '<')
        .replace(/&gt;/gi, '>')
        .replace(/&quot;/gi, '"')
        .replace(/&#39;/g, "'")
        .replace(/\s+/g, ' ')
        .trim();
    }

    function triggerRadio(input) {
      if (!input) return;
      input.checked = true;
      input.dispatchEvent(new Event('input', { bubbles: true }));
      input.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function scheduleStripMainPriceStyles() {
      requestAnimationFrame(function () {
        stripMainPriceRegularInlineStyles();
        setTimeout(stripMainPriceRegularInlineStyles, 0);
        setTimeout(stripMainPriceRegularInlineStyles, 100);
      });
    }

    function planLabelFromInput(input) {
      const label = input.closest('label');
      if (!label) return decodeBasicEntities(input.getAttribute('aria-label') || '');
      const span = label.querySelector('.title_and_price_wrapper span');
      const t = (span && span.textContent) || label.textContent || '';
      return decodeBasicEntities(t);
    }

    function buildUiRoot() {
      const root = document.createElement('div');
      root.className = 'subscription-app-tabs-ui';
      root.setAttribute('data-subscription-tabs-root', '');

      const tabs = document.createElement('div');
      tabs.className = 'subscription-app-tabs-ui__tabs';
      tabs.setAttribute('role', 'tablist');

      const tabOne = document.createElement('button');
      tabOne.type = 'button';
      tabOne.className = 'subscription-app-tabs-ui__tab';
      tabOne.setAttribute('role', 'tab');
      tabOne.setAttribute('aria-selected', 'true');
      tabOne.textContent = decodeBasicEntities({{ 'products.subscription_tabs.one_time' | t | json }});

      const tabSub = document.createElement('button');
      tabSub.type = 'button';
      tabSub.className = 'subscription-app-tabs-ui__tab';
      tabSub.setAttribute('role', 'tab');
      tabSub.setAttribute('aria-selected', 'false');
      tabSub.textContent = decodeBasicEntities({{ 'products.subscription_tabs.subscribe' | t | json }});

      tabs.appendChild(tabOne);
      tabs.appendChild(tabSub);

      const dropWrap = document.createElement('div');
      dropWrap.className = 'subscription-app-tabs-ui__dropdown';
      dropWrap.setAttribute('hidden', '');

      const field = document.createElement('div');
      field.className = 'field';

      const freqLabel = document.createElement('label');
      freqLabel.className = 'label';
      freqLabel.textContent = decodeBasicEntities({{ 'products.subscription_tabs.select_frequency' | t | json }});

      const select = document.createElement('select');
      select.className = 'select';
      select.setAttribute(
        'aria-label',
        decodeBasicEntities({{ 'products.subscription_tabs.select_frequency' | t | json }})
      );

      const selectId =
        'subscription-plan-select-' + String(sectionId).replace(/[^a-zA-Z0-9]/g, '-');
      select.id = selectId;
      freqLabel.setAttribute('for', selectId);

      field.appendChild(freqLabel);
      field.appendChild(select);
      dropWrap.appendChild(field);

      root.appendChild(tabs);
      root.appendChild(dropWrap);

      return {
        root,
        tabOne,
        tabSub,
        dropWrap,
        select,
        freqLabel
      };
    }

    let ui = null;
    let abort = null;
    let mainPriceStyleObserver = null;

    function mainPriceRoot() {
      return document.getElementById('Price-' + String(sectionId) + '-' + String(productId));
    }

    /** Subscriptions app injects inline styles on theme `.price__regular`; strip so theme/CSS controls look. */
    function stripMainPriceRegularInlineStyles() {
      const root = mainPriceRoot();
      if (!root) return;
      root.querySelectorAll('.price__regular').forEach(function (el) {
        el.removeAttribute('style');
      });
    }

    function teardownMainPriceStyleObserver() {
      if (mainPriceStyleObserver) {
        mainPriceStyleObserver.disconnect();
        mainPriceStyleObserver = null;
      }
    }

    function setupMainPriceStyleCleanup() {
      stripMainPriceRegularInlineStyles();
      teardownMainPriceStyleObserver();
      const root = mainPriceRoot();
      if (!root) return;
      mainPriceStyleObserver = new MutationObserver(function () {
        stripMainPriceRegularInlineStyles();
      });
      mainPriceStyleObserver.observe(root, {
        subtree: true,
        attributes: true,
        attributeFilter: ['style'],
        childList: true
      });
    }

    function teardown() {
      abort?.abort();
      abort = null;
      ui?.root.remove();
      ui = null;
      teardownMainPriceStyleObserver();
      const c = getContainer();
      if (c) c.removeAttribute('data-tabs-enhanced');
    }

    function populateSelect(select, inputs) {
      select.innerHTML = '';
      const ph = document.createElement('option');
      ph.value = '';
      ph.disabled = true;
      ph.selected = true;
      ph.textContent = decodeBasicEntities({{ 'products.subscription_tabs.choose_plan' | t | json }});
      select.appendChild(ph);

      inputs.forEach(function (input) {
        const id = input.getAttribute('data-selling-plan-id');
        if (!id) return;
        const opt = document.createElement('option');
        opt.value = id;
        opt.textContent = planLabelFromInput(input);
        select.appendChild(opt);
      });
    }

    function syncSelectToChecked(select, inputs) {
      const checked = inputs.find(function (i) {
        return i.checked;
      });
      if (!checked) {
        select.selectedIndex = 0;
        return;
      }
      const id = checked.getAttribute('data-selling-plan-id');
      const match = Array.from(select.options).find(function (o) {
        return o.value === id;
      });
      if (match) {
        select.value = id;
      }
    }

    function syncFromNative() {
      if (!ui) return;
      const block = getVisibleBlock();
      const oneTime = getOneTimeInput(block);
      const plans = getSellingPlanInputs(block);

      if (plans.length === 0) {
        teardown();
        return;
      }

      populateSelect(ui.select, plans);

      const subChecked = plans.some(function (p) {
        return p.checked;
      });
      const oneChecked = oneTime && oneTime.checked;

      if (subChecked) {
        ui.tabOne.setAttribute('aria-selected', 'false');
        ui.tabSub.setAttribute('aria-selected', 'true');
        ui.dropWrap.removeAttribute('hidden');
        syncSelectToChecked(ui.select, plans);
      } else {
        ui.tabOne.setAttribute('aria-selected', 'true');
        ui.tabSub.setAttribute('aria-selected', 'false');
        ui.dropWrap.setAttribute('hidden', '');
        ui.select.selectedIndex = 0;
      }
    }

    function bindOnce() {
      if (ui) return;
      const container = getContainer();
      if (!container || container.querySelector('[data-subscription-tabs-root]')) return;

      const block = getVisibleBlock();
      if (!block) return;

      const plans = getSellingPlanInputs(block);
      if (plans.length === 0) return;

      const firstSection = container.querySelector('section.shopify_subscriptions_app_block');
      if (!firstSection) return;

      ui = buildUiRoot();
      container.insertBefore(ui.root, firstSection);
      container.setAttribute('data-tabs-enhanced', '');

      abort = new AbortController();
      const signal = abort.signal;

      ui.tabOne.addEventListener(
        'click',
        function () {
          const b = getVisibleBlock();
          triggerRadio(getOneTimeInput(b));
          syncFromNative();
          scheduleStripMainPriceStyles();
        },
        { signal }
      );

      ui.tabSub.addEventListener(
        'click',
        function () {
          const b = getVisibleBlock();
          const list = getSellingPlanInputs(b);
          if (!list.length) return;
          triggerRadio(list[0]);
          syncFromNative();
          scheduleStripMainPriceStyles();
        },
        { signal }
      );

      ui.select.addEventListener(
        'change',
        function () {
          const b = getVisibleBlock();
          const id = ui.select.value;
          if (!id || !b) return;
          const input = b.querySelector(
            'input[type="radio"][data-radio-type="selling_plan"][data-selling-plan-id="' + id + '"]'
          );
          triggerRadio(input);
          scheduleStripMainPriceStyles();
        },
        { signal }
      );

      setupMainPriceStyleCleanup();
      syncFromNative();
    }

    function refresh() {
      const container = getContainer();
      if (!container) {
        teardown();
        return;
      }

      const block = getVisibleBlock();
      const plans = getSellingPlanInputs(block);

      if (!block || plans.length === 0) {
        teardown();
        return;
      }

      if (!ui) {
        bindOnce();
        return;
      }

      populateSelect(ui.select, plans);
      syncFromNative();
      setupMainPriceStyleCleanup();
    }

    function bindVariantUpdates() {
      if (!window.theme || !theme.pubsub) {
        setTimeout(bindVariantUpdates, 50);
        return;
      }
      theme.pubsub.subscribe(theme.pubsub.PUB_SUB_EVENTS.variantChange, function (event) {
        if (String(event.data.sectionId) !== String(sectionId)) return;
        requestAnimationFrame(refresh);
      });
    }

    function poll() {
      const container = getContainer();
      if (!container) return false;
      const block = getVisibleBlock();
      if (!block || !getOneTimeInput(block)) return false;
      return getSellingPlanInputs(block).length > 0;
    }

    let attempts = 0;
    const timer = setInterval(function () {
      attempts += 1;
      if (poll()) {
        clearInterval(timer);
        bindOnce();
        bindVariantUpdates();
        return;
      }
      if (attempts >= 80) {
        clearInterval(timer);
      }
    }, 125);

    document.addEventListener('shopify:section:load', function (ev) {
      if (ev.detail?.sectionId && String(ev.detail.sectionId) !== String(sectionId)) return;
      requestAnimationFrame(refresh);
    });
  })();
</script>
