{%- doc -%}
  Outputs countries using optional theme order (`settings.country_selector_order`).

  @param {string} render_as - `market_links` | `form_anchors` | `select_options`
  @param {string} [current_country_iso] - For active/selected state (form modes)
  @param {string} [eu_override] - Product URL path override for EU market
  @param {string} [us_override]
  @param {string} [uk_override]
{%- enddoc -%}

{%- liquid
  assign country_order_raw = settings.country_selector_order | strip
  assign current_iso = current_country_iso | default: localization.country.iso_code
-%}
{%- if country_order_raw == blank -%}
  {%- for country in localization.available_countries -%}
    {%- case render_as -%}
      {%- when 'market_links' -%}
        {%- render 'localization-country-option',
          country: country,
          eu_override: eu_override,
          us_override: us_override,
          uk_override: uk_override
        -%}
      {%- when 'form_anchors' -%}
        <li class="opacity-0">
          <p>
            <a
              class="reversed-link{% if country.iso_code == current_iso %} active pointer-events-none{% endif %}"
              href="#"
              {% if country.iso_code == current_iso %}
                aria-current="true"
              {% endif %}
              data-value="{{ country.iso_code }}"
              title="{{ country.name | escape }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})"
              data-no-instant
            >
              {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
            </a>
          </p>
        </li>
      {%- when 'select_options' -%}
        <option value="{{ country.iso_code }}"{% if country.iso_code == current_iso %} selected{% endif %}>
          {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
        </option>
    {%- endcase -%}
  {%- endfor -%}
{%- else -%}
  {%- assign ordered_rendered = '|' -%}
  {%- assign order_codes = country_order_raw | split: ',' -%}
  {%- for code_raw in order_codes -%}
    {%- assign order_token = code_raw | strip -%}
    {%- if order_token != blank -%}
      {%- assign order_iso = order_token | upcase -%}
      {%- assign order_name_key = order_token | downcase -%}
      {%- for country in localization.available_countries -%}
        {%- liquid
          assign country_name_key = country.name | downcase
          assign order_matches = false
          if country.iso_code == order_iso
            assign order_matches = true
          elsif country_name_key == order_name_key
            assign order_matches = true
          endif
        -%}
        {%- if order_matches -%}
          {%- assign ordered_marker = '|' | append: country.iso_code | append: '|' -%}
          {%- unless ordered_rendered contains ordered_marker -%}
            {%- case render_as -%}
              {%- when 'market_links' -%}
                {%- render 'localization-country-option',
                  country: country,
                  eu_override: eu_override,
                  us_override: us_override,
                  uk_override: uk_override
                -%}
              {%- when 'form_anchors' -%}
                <li class="opacity-0">
                  <p>
                    <a
                      class="reversed-link{% if country.iso_code == current_iso %} active pointer-events-none{% endif %}"
                      href="#"
                      {% if country.iso_code == current_iso %}
                        aria-current="true"
                      {% endif %}
                      data-value="{{ country.iso_code }}"
                      title="{{ country.name | escape }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})"
                      data-no-instant
                    >
                      {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                    </a>
                  </p>
                </li>
              {%- when 'select_options' -%}
                <option value="{{ country.iso_code }}"{% if country.iso_code == current_iso %} selected{% endif %}>
                  {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                </option>
            {%- endcase -%}
            {%- assign ordered_rendered = ordered_rendered | append: country.iso_code | append: '|' -%}
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  {%- endfor -%}
  {%- for country in localization.available_countries -%}
    {%- assign ordered_marker = '|' | append: country.iso_code | append: '|' -%}
    {%- unless ordered_rendered contains ordered_marker -%}
      {%- case render_as -%}
        {%- when 'market_links' -%}
          {%- render 'localization-country-option',
            country: country,
            eu_override: eu_override,
            us_override: us_override,
            uk_override: uk_override
          -%}
        {%- when 'form_anchors' -%}
          <li class="opacity-0">
            <p>
              <a
                class="reversed-link{% if country.iso_code == current_iso %} active pointer-events-none{% endif %}"
                href="#"
                {% if country.iso_code == current_iso %}
                  aria-current="true"
                {% endif %}
                data-value="{{ country.iso_code }}"
                title="{{ country.name | escape }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})"
                data-no-instant
              >
                {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </a>
            </p>
          </li>
        {%- when 'select_options' -%}
          <option value="{{ country.iso_code }}"{% if country.iso_code == current_iso %} selected{% endif %}>
            {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
          </option>
      {%- endcase -%}
      {%- assign ordered_rendered = ordered_rendered | append: country.iso_code | append: '|' -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}
