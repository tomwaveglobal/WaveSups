{%- doc -%}
  Transforms emphasis tags into visually enhanced text with decorative highlighting effects.

  Replaces standard `<em>` elements with custom highlighted text components.

  @param {string} content - The heading text to display
  @param {string} style - Highlight style type ('scribble', 'none', or other custom styles)
  @param {string} [scribble] - Scribble icon type when using 'scribble' style
  @param {boolean} [reveal] - Enable reveal effect
  @param {boolean} [gradient] - Enable gradient color effects on highlighted text
  @param {number} [delay] - Animation delay multiplier (multiplied by 250ms)

  @example
  {% render 'heading-content',
    content: 'This is example heading.',
    style: 'scribble',
    scribble: 'circle'
  %}
{%- enddoc -%}

{%- if style == 'none' -%}
  {%- if settings.enable_heading_reveal -%}
    <split-words class="split-words js-invisible block" data-animate="fade-up-large"{% if delay %} data-animate-delay="{{ delay | times: 250 }}"{% endif %}>{{ content }}</split-words>
  {%- else -%}
    {{- content -}}
  {%- endif -%}
{%- else -%}
  {%- liquid
    if style == 'text' and gradient
      assign reveal = false
    endif
  -%}
  {%- if reveal -%}
    <split-words class="split-words js-invisible block" data-animate="fade-up-large"{% if delay %} data-animate-delay="{{ delay | times: 250 }}"{% endif %}>
      {%- render 'highlighted-text', content: content, style: style, scribble: scribble, gradient: gradient -%}
    </split-words>
  {%- else -%}
    {%- render 'highlighted-text', content: content, style: style, scribble: scribble, gradient: gradient -%}
  {%- endif -%}
{%- endif -%}
